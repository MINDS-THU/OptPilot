{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optpilot.io/schemas/defs/instances.schema.json",
  "definitions": {
    "instances": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {"enum": ["none", "inline", "files", "sampler"]},
        "value": {"type": "object"},
        "paths": {
          "type": "array",
          "items": {"type": "string"}
        },
        "sampler": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "python": {"$ref": "common.schema.json#/definitions/pythonImport"},
            "pythonPath": {
              "type": "array",
              "items": {"type": "string"}
            },
            "count": {"type": "integer", "minimum": 1},
            "settings": {"type": "object"}
          }
        }
      }
    }
  }
}
