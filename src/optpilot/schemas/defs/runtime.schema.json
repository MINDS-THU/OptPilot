{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optpilot.io/schemas/defs/runtime.schema.json",
  "definitions": {
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sandbox": {
          "enum": ["process", "container"]
        },
        "setup": {"$ref": "common.schema.json#/definitions/setup"},
        "container": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "image": {"type": "string"},
            "executable": {"type": "string"},
            "build": {
              "type": "object",
              "additionalProperties": false,
              "required": ["tag"],
              "properties": {
                "context": {"type": "string"},
                "dockerfile": {"type": "string"},
                "tag": {"type": "string"},
                "target": {"type": "string"},
                "platform": {"type": "string"},
                "args": {
                  "type": "object",
                  "additionalProperties": {"type": "string"}
                },
                "extraArgs": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "timeoutSeconds": {"type": "integer", "minimum": 1}
              }
            },
            "network": {
              "enum": ["enabled", "disabled"]
            }
          },
          "anyOf": [
            {"required": ["image"]},
            {"required": ["build"]}
          ]
        },
        "workdir": {"type": "string"},
        "env": {"$ref": "common.schema.json#/definitions/envObject"},
        "envFromHost": {"$ref": "common.schema.json#/definitions/stringList"}
      },
      "allOf": [
        {
          "if": {
            "required": ["sandbox"],
            "properties": {"sandbox": {"const": "container"}}
          },
          "then": {
            "required": ["container"],
            "not": {"required": ["setup"]}
          },
          "else": {
            "not": {"required": ["container"]}
          }
        }
      ]
    }
  }
}
