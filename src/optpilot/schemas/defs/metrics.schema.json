{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optpilot.io/schemas/defs/metrics.schema.json",
  "definitions": {
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": {"enum": ["return", "file", "stdout", "sqlite", "custom"]},
        "keys": {
          "type": "array",
          "items": {"type": "string"}
        },
        "path": {"type": "string"},
        "database": {"type": "string"},
        "query": {"type": "string"},
        "extractor": {"$ref": "common.schema.json#/definitions/pythonImport"},
        "settings": {"type": "object"}
      },
      "oneOf": [
        {
          "properties": {"source": {"const": "return"}},
          "not": {
            "anyOf": [
              {"required": ["path"]},
              {"required": ["database"]},
              {"required": ["query"]},
              {"required": ["extractor"]},
              {"required": ["settings"]}
            ]
          }
        },
        {
          "required": ["path"],
          "properties": {"source": {"const": "file"}},
          "not": {
            "anyOf": [
              {"required": ["database"]},
              {"required": ["query"]},
              {"required": ["extractor"]}
            ]
          }
        },
        {
          "properties": {"source": {"const": "stdout"}},
          "not": {
            "anyOf": [
              {"required": ["path"]},
              {"required": ["database"]},
              {"required": ["query"]},
              {"required": ["extractor"]},
              {"required": ["settings"]}
            ]
          }
        },
        {
          "required": ["database", "query"],
          "properties": {"source": {"const": "sqlite"}},
          "not": {
            "anyOf": [
              {"required": ["path"]},
              {"required": ["extractor"]}
            ]
          }
        },
        {
          "required": ["extractor"],
          "properties": {"source": {"const": "custom"}},
          "not": {
            "anyOf": [
              {"required": ["path"]},
              {"required": ["database"]},
              {"required": ["query"]}
            ]
          }
        }
      ]
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source"],
      "properties": {
        "name": {"type": "string"},
        "source": {"enum": ["jsonl", "csv", "sqlite_table", "sqlite_query", "custom"]},
        "path": {"type": "string"},
        "database": {"type": "string"},
        "table": {"type": "string"},
        "query": {"type": "string"},
        "extractor": {"$ref": "common.schema.json#/definitions/pythonImport"},
        "settings": {"type": "object"}
      },
      "oneOf": [
        {
          "required": ["path"],
          "properties": {"source": {"const": "jsonl"}},
          "not": {
            "anyOf": [
              {"required": ["database"]},
              {"required": ["table"]},
              {"required": ["query"]},
              {"required": ["extractor"]}
            ]
          }
        },
        {
          "required": ["path"],
          "properties": {"source": {"const": "csv"}},
          "not": {
            "anyOf": [
              {"required": ["database"]},
              {"required": ["table"]},
              {"required": ["query"]},
              {"required": ["extractor"]}
            ]
          }
        },
        {
          "required": ["database", "table"],
          "properties": {"source": {"const": "sqlite_table"}},
          "not": {
            "anyOf": [
              {"required": ["path"]},
              {"required": ["query"]},
              {"required": ["extractor"]}
            ]
          }
        },
        {
          "required": ["database", "query"],
          "properties": {"source": {"const": "sqlite_query"}},
          "not": {
            "anyOf": [
              {"required": ["path"]},
              {"required": ["table"]},
              {"required": ["extractor"]}
            ]
          }
        },
        {
          "required": ["extractor"],
          "properties": {"source": {"const": "custom"}},
          "not": {
            "anyOf": [
              {"required": ["path"]},
              {"required": ["database"]},
              {"required": ["table"]},
              {"required": ["query"]}
            ]
          }
        }
      ]
    },
    "outputFile": {
      "oneOf": [
        {"type": "string"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": {
            "path": {"type": "string"},
            "name": {"type": "string"},
            "required": {"type": "boolean"}
          }
        }
      ]
    }
  }
}
