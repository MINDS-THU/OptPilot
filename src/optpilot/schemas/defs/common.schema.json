{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optpilot.io/schemas/defs/common.schema.json",
  "definitions": {
    "apiVersion": {
      "const": "optpilot.io/v1"
    },
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "pythonImport": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*:[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*$"
    },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "port"],
      "properties": {
        "label": {"type": "string"},
        "description": {"type": "string"},
        "command": {"$ref": "#/definitions/command"},
        "port": {"type": "integer", "minimum": 1, "maximum": 65535},
        "cwd": {"type": "string"},
        "env": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "extraPorts": {
          "type": "array",
          "items": {"type": "integer", "minimum": 1, "maximum": 65535}
        },
        "readyPath": {"type": "string"},
        "readyTimeoutSeconds": {"type": "integer", "minimum": 0, "maximum": 600}
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "object": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
