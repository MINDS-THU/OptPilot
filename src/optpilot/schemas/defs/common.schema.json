{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optpilot.io/schemas/defs/common.schema.json",
  "definitions": {
    "apiVersion": {
      "const": "optpilot.io/v1"
    },
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "pythonImport": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*:[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*$"
    },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "envObject": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "setup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/definitions/setupStep"}
        },
        "env": {"$ref": "#/definitions/envObject"},
        "envFromHost": {"$ref": "#/definitions/stringList"},
        "timeoutSeconds": {"type": "integer", "minimum": 1}
      }
    },
    "setupStep": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["uses"],
          "properties": {
            "uses": {"const": "uv"},
            "cwd": {"type": "string"},
            "env": {"$ref": "#/definitions/envObject"},
            "extras": {"$ref": "#/definitions/stringList"},
            "groups": {"$ref": "#/definitions/stringList"},
            "frozen": {"type": "boolean"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["uses"],
          "properties": {
            "uses": {"const": "python-venv"},
            "cwd": {"type": "string"},
            "env": {"$ref": "#/definitions/envObject"},
            "python": {"type": "string"},
            "venv": {"type": "string"},
            "requirements": {"$ref": "#/definitions/stringList"},
            "installProject": {"type": "boolean"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["uses"],
          "properties": {
            "uses": {"const": "npm"},
            "cwd": {"type": "string"},
            "env": {"$ref": "#/definitions/envObject"},
            "install": {"enum": ["ci", "install"]}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["uses", "command"],
          "properties": {
            "uses": {"const": "command"},
            "cwd": {"type": "string"},
            "env": {"$ref": "#/definitions/envObject"},
            "command": {"$ref": "#/definitions/command"}
          }
        }
      ]
    },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "port"],
      "properties": {
        "label": {"type": "string"},
        "description": {"type": "string"},
        "command": {"$ref": "#/definitions/command"},
        "port": {"type": "integer", "minimum": 1, "maximum": 65535},
        "cwd": {"type": "string"},
        "env": {"$ref": "#/definitions/envObject"},
        "envFromHost": {"$ref": "#/definitions/stringList"},
        "setup": {"$ref": "#/definitions/setup"},
        "extraPorts": {
          "type": "array",
          "items": {"type": "integer", "minimum": 1, "maximum": 65535}
        },
        "readyPath": {"type": "string"},
        "readyTimeoutSeconds": {"type": "integer", "minimum": 0, "maximum": 600}
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "object": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
