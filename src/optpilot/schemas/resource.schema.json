{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optpilot.io/schemas/resource.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "config", "id"],
  "properties": {
    "apiVersion": {"$ref": "defs/common.schema.json#/definitions/apiVersion"},
    "config": {"const": "resource"},
    "id": {"$ref": "defs/common.schema.json#/definitions/identifier"},
    "name": {"type": "string"},
    "description": {"$ref": "defs/common.schema.json#/definitions/description"},
    "tags": {"$ref": "defs/common.schema.json#/definitions/tags"},
    "interface": {"$ref": "defs/common.schema.json#/definitions/interface"}
  }
}
