{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optpilot.io/schemas/study.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "config", "name", "environmentConfig", "methodConfig", "objective", "budget"],
  "properties": {
    "apiVersion": {"$ref": "defs/common.schema.json#/definitions/apiVersion"},
    "config": {"const": "study"},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "tags": {"$ref": "defs/common.schema.json#/definitions/tags"},
    "environmentConfig": {"type": "string"},
    "methodConfig": {"type": "string"},
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric", "direction"],
      "properties": {
        "metric": {"type": "string"},
        "direction": {"enum": ["maximize", "minimize"]},
        "aggregation": {"enum": ["mean", "median", "min", "max", "sum", "last", "weighted_mean"]},
        "secondaryMetrics": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxTrials"],
      "properties": {
        "maxTrials": {"type": "integer", "minimum": 1},
        "maxWallClockSeconds": {"type": "integer", "minimum": 1},
        "maxFailures": {"type": "integer", "minimum": 1}
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": {"enum": ["local", "local_subprocess"]},
        "parallelism": {"type": "integer", "minimum": 1},
        "timeoutSeconds": {"type": "integer", "minimum": 1},
        "runtime": {"$ref": "defs/runtime.schema.json#/definitions/runtime"},
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxRetries": {"type": "integer", "minimum": 0}
          }
        },
        "settings": {"type": "object"}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {"enum": ["minimal", "standard", "full"]},
        "outputFileStorage": {"enum": ["reference", "copy"]},
        "outputDir": {"type": "string"}
      }
    },
    "reproducibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "seed": {"type": "integer"}
      }
    }
  }
}
