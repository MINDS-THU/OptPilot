{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optpilot.io/schemas/method.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "config", "id", "entrypoint", "accepts"],
  "properties": {
    "apiVersion": {"$ref": "defs/common.schema.json#/definitions/apiVersion"},
    "config": {"const": "method"},
    "id": {"$ref": "defs/common.schema.json#/definitions/identifier"},
    "description": {"$ref": "defs/common.schema.json#/definitions/description"},
    "tags": {"$ref": "defs/common.schema.json#/definitions/tags"},
    "entrypoint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "python": {"$ref": "defs/common.schema.json#/definitions/pythonImport"},
        "pythonPath": {"$ref": "defs/common.schema.json#/definitions/stringList"},
        "command": {"$ref": "defs/common.schema.json#/definitions/command"},
        "protocol": {"enum": ["batch", "session"]}
      },
      "oneOf": [
        {"required": ["python"]},
        {"required": ["command"]}
      ]
    },
    "settings": {"type": "object"},
    "accepts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formats"],
      "properties": {
        "formats": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["parameters", "files", "opaque"]}
        },
        "requires": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "context": {
              "type": "array",
              "items": {"type": "string"}
            },
            "capabilities": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    },
    "runtime": {"$ref": "defs/runtime.schema.json#/definitions/runtime"},
    "resourceProfile": {"$ref": "defs/runtime.schema.json#/definitions/resourceProfile"}
  }
}
